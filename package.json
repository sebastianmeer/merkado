{
    "name": "marketplace",
    "version": "1.0.0",
    "description": "A Local Marketplace API for community trading - buy, sell, and browse items in your neighborhood.",
    "main": "server.ts",
    "type": "module",
    "scripts": {
        "prestart": "tsx scripts/ensure-client-build.ts",
        "start": "tsx server.ts",
        "start:dev": "tsx watch server.ts",
        "build": "tsx scripts/ensure-client-build.ts && tsc -p tsconfig.json --noEmit",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "client:dev": "npm --prefix client run dev",
        "client:build": "npm --prefix client run build",
        "data:import": "tsx import-dev-data.ts --import",
        "data:delete": "tsx import-dev-data.ts --delete"
    },
    "keywords": [
        "marketplace",
        "express",
        "api",
        "community"
    ],
    "author": "GT1C-MEER",
    "license": "ISC",
    "dependencies": {
        "bcryptjs": "^3.0.3",
        "cookie-parser": "^1.4.7",
        "dotenv": "^17.3.1",
        "express": "^5.2.1",
        "express-mongo-sanitize": "^2.2.0",
        "express-rate-limit": "^8.4.1",
        "helmet": "^8.1.0",
        "hpp": "^0.2.3",
        "jsonwebtoken": "^9.0.3",
        "mongoose": "^9.3.1",
        "nodemailer": "^8.0.7",
        "slugify": "^1.6.8",
        "validator": "^13.15.35",
        "xss-clean": "^0.1.4"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/cookie-parser": "^1.4.10",
        "@types/express": "^5.0.6",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/morgan": "^1.9.10",
        "@types/node": "^25.9.3",
        "@types/validator": "^13.15.10",
        "morgan": "^1.10.1",
        "nodemon": "^3.1.14",
        "tsx": "^4.22.4",
        "typescript": "^6.0.3"
    }
}
